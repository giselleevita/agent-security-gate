AUDIT_LOG_PATH=results/audit.jsonl
TENANT_ID=demo-tenant
REDIS_URL=redis://redis:6379
AGENT_RATE_LIMIT_MAX=5
AGENT_RATE_LIMIT_WINDOW_S=60
DECIDE_RATE_LIMIT_MAX=120
DECIDE_RATE_LIMIT_WINDOW_S=60
APPROVAL_RATE_LIMIT_MAX=20
APPROVAL_RATE_LIMIT_WINDOW_S=60
APPROVAL_TTL_S=3600
DLP_PATTERNS_PATH=policies/data/dlp_patterns.yaml
CANARIES_PATH=policies/data/canaries.yaml
# Per-tenant policies live at policies/data/tenants/{tenant_id}/policy_data.json and
# override the default. Set strict mode in multi-tenant production so a tenant without a
# dedicated policy file is denied (unknown_tenant) rather than inheriting the default.
ASG_TENANT_POLICY_STRICT=false
ASG_DEMO_MODE=true
AUTH_TOKEN=test-token
APPROVER_TOKEN=approver-token
JWT_SECRET=asg-demo-jwt-secret-minimum-32-bytes
# In production (ASG_DEMO_MODE=false), provide real secrets either directly as above or
# via file paths using the _FILE suffix (takes effect when the direct var is unset), e.g.:
# AUTH_TOKEN_FILE=/run/secrets/auth_token
# APPROVER_TOKEN_FILE=/run/secrets/approver_token
# JWT_SECRET_FILE=/run/secrets/jwt_secret
# The gateway refuses to start if required secrets are missing or still the demo values.
# OIDC identity (optional): when OIDC_ISSUER + OIDC_AUDIENCE are set, signed OIDC JWTs
# with roles asg:agent / asg:approver are accepted alongside static tokens. With OIDC
# enabled, the static agent/approver tokens become optional (JWT_SECRET is still required).
# OIDC_ISSUER=https://your-idp.example.com/realms/asg
# OIDC_AUDIENCE=asg-api
# OIDC_JWKS_URL=  # optional; defaults to {OIDC_ISSUER}/.well-known/jwks.json
# Audit integrity (optional): sign each entry so a recomputed hash chain still fails
# verification without the key, and mirror entries to an immutable S3 Object Lock bucket.
# AUDIT_HMAC_KEY=  # or AUDIT_HMAC_KEY_FILE=/run/secrets/audit_hmac_key
# AUDIT_S3_BUCKET=asg-audit           # requires the 's3' extra (boto3)
# AUDIT_S3_PREFIX=audit/
# AUDIT_S3_REGION=us-east-1
# AUDIT_S3_ENDPOINT_URL=              # e.g. http://minio:9000 for MinIO/LocalStack
# AUDIT_S3_RETENTION_DAYS=0          # >0 sets per-object WORM retention
# AUDIT_S3_OBJECT_LOCK_MODE=GOVERNANCE  # or COMPLIANCE
# Tool-execution enforcement (connector SDK): require a prior /v1/gateway/decide allow
# before a tool endpoint runs. off (default) | permissive (verify when audit_id present) |
# strict (mandatory, 403 without a valid single-use grant). See docs/connector-sdk.md.
ASG_ENFORCE_MODE=off
ASG_ENFORCE_TTL_S=300
